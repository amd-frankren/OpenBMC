From 0ec4eb95afb0e5931ab13a1dee8ee8d876c130c5 Mon Sep 17 00:00:00 2001
From: Abinaya Dhandapani <abinaya.dhandapani@amd.com>
Date: Tue, 20 May 2025 02:17:03 -0500
Subject: [PATCH] com.amd: Add crashdump interface

The crashdump interface addition to download
CPER files from redfish that are available in BMC.

Upstream-Status: Pending

Signed-off-by: Abinaya Dhandapani <abinaya.dhandapani@amd.com>
---
 yaml/com/amd/crashdump.interface.yaml | 22 ++++++++++++++++++++++
 1 file changed, 22 insertions(+)
 create mode 100644 yaml/com/amd/crashdump.interface.yaml

diff --git a/yaml/com/amd/crashdump.interface.yaml b/yaml/com/amd/crashdump.interface.yaml
new file mode 100644
index 0000000..fb70f91
--- /dev/null
+++ b/yaml/com/amd/crashdump.interface.yaml
@@ -0,0 +1,22 @@
+description: >
+    This interface provides details about Common Platform Error Record (CPER)
+    files that are available on the BMC. Each CPER file is represented as a CPER
+    Record object, which holds key attributes of the file.
+properties:
+    - name: Filename
+      type: string
+      description: >
+          The name of the CPER file stored on the BMC. This attribute uniquely
+          identifies the file and can be used to locate or refer to the specific
+          CPER file in the system.
+    - name: Timestamp
+      type: string
+      description: >
+          Indicates the time when the CPER file was generated. This timestamp
+          provides critical information for correlating the error record with
+          system events or logs, aiding in diagnostics and root cause analysis.
+    - name: Log
+      type: string
+      description: >
+          An additional string that gives the file path of the CPER files
+          saved in the BMC.
--
