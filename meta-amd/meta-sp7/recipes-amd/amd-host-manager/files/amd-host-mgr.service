[Unit]
Description=Service for monitoring and managing host state transitions.
Requires=xyz.openbmc_project.Chassis.Control.Power@0.service
After=xyz.openbmc_project.Chassis.Control.Power@0.service

[Service]
Type=simple
ExecStart=/usr/sbin/amd-host-mgr
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
