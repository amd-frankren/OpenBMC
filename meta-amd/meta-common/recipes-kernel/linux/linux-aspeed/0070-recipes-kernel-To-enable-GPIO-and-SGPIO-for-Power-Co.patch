+++ b/arch/arm/boot/dts/aspeed-bmc-amd-marley-i3c.dts
@@ -106,7 +106,7 @@ flash@0 {
 &spi2 {
 	status = "okay";
 	pinctrl-names = "default";
-	pinctrl-0 = <&pinctrl_spi2_default &pinctrl_qspi2_default>;
+	pinctrl-0 = <&pinctrl_spi2_default &pinctrl_spi2_default>;
 	fmc-spi-user-mode;
 	compatible = "aspeed,ast2600-spi";

@@ -657,7 +657,7 @@ &espi_mmbi {
 &gpio0 {
 	gpio-line-names =
 	/*A0-A7*/       "","","","","","","","",
-	/*B0-B7*/       "","","","","","","","",
+	/*B0-B7*/       "","","MON_RST_BTN_L","P0_THERMTRIP_L","","","","",
 	/*C0-C7*/       "","","","","","","","",
 	/*D0-D7*/       "","","","","","","","",
 	/*E0-E7*/       "","","","","","","","",
@@ -674,13 +674,13 @@ &gpio0 {
 	/*P0-P7*/       "","","","","","","","",
 	/*Q0-Q7*/       "","","","","","","","",
 	/*R0-R7*/       "","","","","","","","",
-	/*S0-S7*/       "","","","","","","","",
+	/*S0-S7*/       "","","","","","","MON_PWR_GOOD","",
 	/*T0-T7*/       "","","","","","","","",
 	/*U0-U7*/       "","","","","","","","",
 	/*V0-V7*/       "","","","","","","","",
 	/*W0-W7*/       "","","","","","","","",
 	/*X0-X7*/       "","","","","","","","",
-	/*Y0-Y7*/       "ASSERT_BMC_READY","","","","","","","",
+	/*Y0-Y7*/       "ASSERT_BMC_READY","","MON_PWR_BTN_L","","","","","",
 	/*Z0-Z7*/       "","","","","","","","";
 };

@@ -688,7 +688,23 @@ &sgpiom0 {
 	status = "okay";
 	ngpios = <128>;
 	bus-frequency = <12000000>;
-
+		gpio-line-names =
+			/*SA0-SA7*/       "","","","","","","","",
+			/*SB0-SB7*/       "","","","","MON_POST_COMPLETE","","","",
+			/*SC0-SC7*/       "","","","","","","","",
+			/*SD0-SD7*/       "","","","","","","","",
+			/*SE0-SE7*/       "","","P1_THERMTRIP_L","","","","","",
+			/*SF0-SF7*/       "","","","","","","","",
+			/*SG0-SG7*/       "","","","P1_ASSERT_WARM_RST_BTN_L","","","","P1_ASSERT_RST_BTN_L",
+			/*SH0-SH7*/       "","RSMRST","","ASSERT_WARM_RST_BTN_L","","","","",
+			/*SI0-SI7*/       "","","","","","","","",
+			/*SJ0-SJ7*/       "","","","","","","","",
+			/*SK0-SK7*/       "","","","","","","","",
+			/*SL0-SL7*/       "","P1_ASSERT_PWR_BTN_L","","P1_ASSERT_NMI_BTN_L","","","","",
+			/*SM0-SM7*/       "","","","","","","","",
+			/*SN0-SN7*/       "","","","","","","","",
+			/*SO0-SO7*/       "","","","","","","","",
+			/*SP0-SP7*/       "","ASSERT_RST_BTN_L","","ASSERT_PWR_BTN_L","","ASSERT_NMI_BTN_L","","";
 };

 &sgpiom1 {
