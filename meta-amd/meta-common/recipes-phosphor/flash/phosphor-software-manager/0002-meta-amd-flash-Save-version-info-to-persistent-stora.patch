From a88ec4466877e628fddfbf710c1d471a4bc89232 Mon Sep 17 00:00:00 2001
From: aasboddu <Aashray.Boddu@amd.com>
Date: Tue, 3 Sep 2024 13:28:07 -0500
Subject: [PATCH] meta-amd: flash: Save version info to persistent storage

Save firmware version to persistent storage and
display it in the GUI after BMC reboot or AC cycle.

Signed-off-by: aasboddu <Aashray.Boddu@amd.com>
---
 activation.cpp   | 12 ++++++++++++
 item_updater.cpp | 23 +++++++++++++++++++++--
 item_updater.hpp | 11 +++++++++++
 3 files changed, 44 insertions(+), 2 deletions(-)

diff --git a/activation.cpp b/activation.cpp
index aba7d2f..c828401 100644
--- a/activation.cpp
+++ b/activation.cpp
@@ -13,11 +13,21 @@
 #include <sdbusplus/exception.hpp>
 #include <xyz/openbmc_project/Common/error.hpp>
 #include <xyz/openbmc_project/Software/Version/error.hpp>
+#include <cereal/archives/json.hpp>

 #ifdef WANT_SIGNATURE_VERIFY
 #include "image_verify.hpp"
 #endif

+#define    SET_VER(file)        { \
+            std::ofstream os(PERSIST_DIR file); \
+            { \
+                cereal::JSONOutputArchive oarchive(os);\
+                oarchive(cereal::make_nvp(ACTIVE_VER_KEY, parent.versions.find(versionId)->second->version())); \
+            } \
+            os.close();\
+}
+
 extern boost::asio::io_context& getIOContext();

 namespace phosphor
@@ -460,6 +470,7 @@ void Activation::onStateChangesBios(sdbusplus::message_t& msg)
             info("Bios upgrade completed successfully.");
             parent.biosVersion->version(
                 parent.versions.find(versionId)->second->version());
+            SET_VER(BIOS_VER_FILE);

             // Delete the uploaded activation
             boost::asio::post(getIOContext(), [this]() {
@@ -526,6 +537,7 @@ void Activation::onStateChangesHpmFpga(sdbusplus::message::message& msg)
             info("HPM FPGA upgrade completed successfully.");
             parent.hpmfpgaVersion->version(
                 parent.versions.find(versionId)->second->version());
+            SET_VER(HPM_VER_FILE);

             // Delete the uploaded activation
             boost::asio::post(getIOContext(), [this]() {
diff --git a/item_updater.cpp b/item_updater.cpp
index 40d43be..7a16a70 100644
--- a/item_updater.cpp
+++ b/item_updater.cpp
@@ -13,6 +13,7 @@
 #include <phosphor-logging/lg2.hpp>
 #include <xyz/openbmc_project/Common/error.hpp>
 #include <xyz/openbmc_project/Software/Image/error.hpp>
+#include <cereal/archives/json.hpp>

 #include <filesystem>
 #include <fstream>
@@ -21,6 +22,22 @@
 #include <string>
 #include <system_error>

+#define GET_VER(file)   {\
+        std::string line; \
+        std::ifstream is(PERSIST_DIR file, std::ios::in); \
+        try \
+        { \
+            cereal::JSONInputArchive iarchive(is); \
+                iarchive(cereal::make_nvp(ACTIVE_VER_KEY, line)); \
+            version = line.c_str(); \
+        } \
+        catch (cereal::Exception& e) \
+        { \
+            fs::remove_all(path); \
+        } \
+        is.close(); \
+    }
+
 namespace phosphor
 {
 namespace software
@@ -865,7 +882,8 @@ void ItemUpdater::createBIOSObject()
     createUpdateableAssociation(path);

     auto versionId = path.substr(pos + 1);
-    auto version = "null";
+    auto version = "Unknown";
+    GET_VER(BIOS_VER_FILE);
     AssociationList assocs = {};
     biosActivation = std::make_unique<Activation>(
         bus, path, *this, versionId, server::Activation::Activations::Active,
@@ -900,7 +918,8 @@ void ItemUpdater::createHPMFPGAObject()
      createUpdateableAssociation(path);

     auto versionId = path.substr(pos + 1);
-    auto version = "null";
+    auto version = "Unknown";
+    GET_VER(HPM_VER_FILE);

     AssociationList assocs = {};
     hpmfpgaActivation = std::make_unique<Activation>(
diff --git a/item_updater.hpp b/item_updater.hpp
index ab1f712..add9132 100644
--- a/item_updater.hpp
+++ b/item_updater.hpp
@@ -15,6 +15,17 @@
 #include <string>
 #include <vector>

+#ifdef HOST_BIOS_UPGRADE
+#define BIOS_VER_FILE  "bios_ver"
+#endif
+#ifdef SCM_FPGA_UPGRADE
+#define SCM_VER_FILE   "scm_ver"
+#endif
+#ifdef HPM_FPGA_UPGRADE
+#define HPM_VER_FILE   "hpm_ver"
+#endif
+#define ACTIVE_VER_KEY "active"
+
 namespace phosphor
 {
 namespace software
--
2.34.1

