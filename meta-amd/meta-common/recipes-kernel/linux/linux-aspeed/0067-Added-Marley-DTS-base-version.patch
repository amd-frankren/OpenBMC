Content-Transfer-Encoding: 7bit

Signed-off-by: Ashok Kumar <ashok2.kumar@amd.com>
---
 arch/arm/boot/dts/Makefile                    |   2 +
 .../boot/dts/aspeed-bmc-amd-marley-i3c.dts    | 214 +++++++++++++++++
 arch/arm/boot/dts/aspeed-bmc-amd-marley.dts   | 215 ++++++++++++++++++
 3 files changed, 431 insertions(+)
 create mode 100644 arch/arm/boot/dts/aspeed-bmc-amd-marley-i3c.dts
 create mode 100644 arch/arm/boot/dts/aspeed-bmc-amd-marley.dts

