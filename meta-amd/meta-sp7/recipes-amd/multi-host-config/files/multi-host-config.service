[Unit]
Description=Service for monitoring and managing multi-host transitions.
Requires=xyz.openbmc_project.Chassis.Control.Power@0.service
After=xyz.openbmc_project.Chassis.Control.Power@0.service

[Service]
Type=simple
ExecStart=/usr/sbin/multi-host-config.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
