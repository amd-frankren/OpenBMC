diff --git a/src/store/modules/Operations/MultiHostSelectionStore.js b/src/store/modules/Operations/MultiHostSelectionStore.js
new file mode 100644
index 0000000..e13eb96
--- /dev/null
+++ b/src/store/modules/Operations/MultiHostSelectionStore.js
@@ -0,0 +1,46 @@
+import api from '@/store/api';
+import i18n from '@/i18n';
+
+const MultiHostSelectionStore = {
+  namespaced: true,
+  state: {
+    multihostOption: null,
+  },
+  getters: {
+    multihostOption: (state) => state.multihostOption,
+  },
+  mutations: {
+    setSelectedSetting(state, value) {
+      state.multihostOption = value;
+    },
+  },
+  actions: {
+    async getMultiHostSetting({ commit }) {
+      return await api
+        .get('/redfish/v1/Systems/system/MultiHost')
+        .then((response) => {
+          const parsedValue = String(response.data.Mode);
+          commit('setSelectedSetting', parsedValue);
+        })
+        .catch((error) => {
+          console.log('multi host get', error);
+        });
+    },
+    async setMultiHostSetting({ state }) {
+      const configMode = state.multihostOption;
+      console.log(configMode);
+      const data = {
+        Mode: configMode === '0' ? 0 : 1,
+      };
+      return await api
+        .post('/redfish/v1/Systems/system/MultiHost', data)
+        .then(() => i18n.t('pageMultiHost.toast.resetMultiHostSuccess'))
+        .catch((error) => {
+          console.log('multi host set: ', error);
+          throw new Error(i18n.t('pageMultiHost.toast.resetMultiHostError'));
+        });
+    },
+  },
+};
+
+export default MultiHostSelectionStore;
diff --git a/src/views/Operations/MultiHost/MultiHost.vue b/src/views/Operations/MultiHost/MultiHost.vue
new file mode 100644
index 0000000..5d5fcc6
--- /dev/null
+++ b/src/views/Operations/MultiHost/MultiHost.vue
@@ -0,0 +1,92 @@
+<template>
+  <b-container fluid="xl">
+    <page-title :description="$t('pageMultiHost.description')" />
+
+    <!-- Reset Form -->
+    <b-form id="multi-host" @submit.prevent="onMultiHostSelectionSubmit">
+      <b-row>
+        <b-col md="8">
+          <b-form-group :label="$t('pageMultiHost.form.multiHostLable')">
+            <b-form-radio-group
+              id="multi-host-options"
+              v-model="multihostOption"
+              stacked
+            >
+              <b-form-radio
+                class="mb-1"
+                value="0"
+                aria-describedby="reset-2p"
+                data-test-id="multihostnode-radio-reset2p"
+              >
+                {{ $t('pageMultiHost.form.2pmodeLabel') }}
+              </b-form-radio>
+              <b-form-radio
+                class="mb-1"
+                value="1"
+                aria-describedby="reset-2x1p"
+                data-test-id="multihostnode-radio-reset2x1p"
+              >
+                {{ $t('pageMultiHost.form.2x1pmodeLabel') }}
+              </b-form-radio>
+            </b-form-radio-group>
+          </b-form-group>
+          <b-button
+            type="submit"
+            variant="primary"
+            data-test-id="multihostnode-button-submit"
+          >
+            {{ $t('global.action.saveSettings') }}
+          </b-button>
+        </b-col>
+      </b-row>
+    </b-form>
+  </b-container>
+</template>
+
+<script>
+import PageTitle from '@/components/Global/PageTitle';
+import BVToastMixin from '@/components/Mixins/BVToastMixin';
+import LoadingBarMixin from '@/components/Mixins/LoadingBarMixin';
+import { mapGetters } from 'vuex';
+
+export default {
+  name: 'MultiHostSelection',
+  components: { PageTitle },
+  mixins: [LoadingBarMixin, BVToastMixin],
+  computed: {
+    ...mapGetters('multihostSelection', {
+      storeMultihostOption: 'multihostOption',
+    }),
+    multihostOption: {
+      get() {
+        return this.storeMultihostOption;
+      },
+      set(value) {
+        this.$store.commit('multihostSelection/setSelectedSetting', value);
+      },
+    },
+  },
+  created() {
+    this.startLoader();
+    this.$store
+      .dispatch('multihostSelection/getMultiHostSetting')
+      .finally(() => this.endLoader());
+  },
+  methods: {
+    onMultiHostSelectionSubmit() {
+      this.$store
+        .dispatch('multihostSelection/setMultiHostSetting')
+        .then((title) => {
+          this.successToast('', {
+            title,
+          });
+        })
+        .catch(({ message }) => {
+          this.errorToast('', {
+            title: message,
+          });
+        });
+    },
+  },
+};
+</script>
