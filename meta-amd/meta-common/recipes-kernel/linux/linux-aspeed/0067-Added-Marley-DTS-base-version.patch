 	aspeed-bmc-amd-purico.dtb \
 	aspeed-bmc-amd-recluse.dtb \
 	aspeed-bmc-amd-volcano.dtb \
+	aspeed-bmc-amd-marley.dtb \
+	aspeed-bmc-amd-marley-i3c.dtb \
 	aspeed-bmc-amd-parrypeak.dtb \
 	aspeed-bmc-amd-sh5d807.dtb \
